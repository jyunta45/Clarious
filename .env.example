# ============================================
# Life Assistant — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --------------------------------------------
# REQUIRED
# --------------------------------------------

# PostgreSQL connection string
# Used for: user accounts, session storage, all app data
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/life_assistant

# Anthropic API key
# Used for: all AI responses (Claude Sonnet + Haiku)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# OPTIONAL (have defaults)
# --------------------------------------------

# Session encryption secret
# Used for: encrypting user session cookies
# Default: 'life-assistant-dev-secret' (NOT safe for production)
# Generate a strong random string for production
SESSION_SECRET=your-random-secret-string-here

# Server port
# Default: 5000
PORT=5000

# Node environment
# Values: development | production
# Default: development
# Set to 'production' for secure cookies and optimized builds
NODE_ENV=development
